pipeline {
    agent any

    environment {
        SITE_PATH = '/home/leo/docker/static-site'
        BACKUP_PATH = '/home/leo/docker/static-site-backups'
        REPO_URL = 'https://github.com/LeonardoJaques/jaquesprojetos.git'
    }

    stages {
        stage('🔄 Backup') {
            steps {
                script {
                    try {
                        sh '''
                            echo "📦 Criando backup..."
                            TIMESTAMP=$(date +%Y%m%d_%H%M%S)
                            mkdir -p ${BACKUP_PATH}
                            tar -czf ${BACKUP_PATH}/backup_${TIMESTAMP}.tar.gz -C ${SITE_PATH} . 2>/dev/null || true
                            echo "🗑️ Mantendo apenas 5 últimos backups..."
                            cd ${BACKUP_PATH}
                            ls -t backup_*.tar.gz 2>/dev/null | tail -n +6 | xargs -r rm
                            echo "✅ Backup concluído!"
                        '''
                    } catch (e) {
                        echo "⚠️ Backup falhou (não crítico): ${e.message}"
                    }
                }
            }
        }

        stage('📥 Clone Repository') {
            steps {
                git branch: 'main', url: "${REPO_URL}"
            }
        }

        stage('✅ Validar Arquivos') {
            steps {
                sh '''
                    if [ ! -f "index.html" ]; then
                        echo "ERRO: index.html não encontrado!"
                        exit 1
                    fi
                    echo "✅ Arquivos validados!"
                '''
            }
        }

        stage('🚀 Deploy') {
            steps {
                sh '''
                    echo "🚀 Iniciando deploy..."
                    mkdir -p ${SITE_PATH}
                    find ${SITE_PATH} -mindepth 1 -delete
                    cp -r * ${SITE_PATH}/
                    chmod -R 755 ${SITE_PATH}
                    echo "✅ Arquivos copiados!"
                '''
            }
        }

        stage('🔍 Verificar Deploy') {
            steps {
                sh '''
                    sleep 2
                    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" https://jaquesprojetos.com.br)
                    if [ "$HTTP_CODE" != "200" ]; then
                        echo "ERRO: Site retornou código $HTTP_CODE"
                        exit 1
                    fi
                    echo "✅ Deploy verificado! Código: $HTTP_CODE"
                '''
            }
        }

    }

    post {
        success {
            echo '✅ Deploy realizado com sucesso! 🚀'
        }
        failure {
            echo '❌ Deploy falhou! Restaurando backup...'
            sh '''
                LAST_BACKUP=$(ls -t ${BACKUP_PATH}/backup_*.tar.gz 2>/dev/null | head -n 1)
                if [ -f "$LAST_BACKUP" ]; then
                    echo "♻️ Restaurando: $LAST_BACKUP"
                    tar -xzf $LAST_BACKUP -C ${SITE_PATH}
                    systemctl reload nginx
                    echo "✅ Backup restaurado!"
                else
                    echo "⚠️ Nenhum backup encontrado"
                fi
            '''
        }
    }
}
